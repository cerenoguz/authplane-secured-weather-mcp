# Local AuthPlane server configuration.
# Copy this file to .env.authplane and replace placeholder values.
AUTHPLANE_ADMIN_API_KEY=generate-a-random-64-character-hex-value
AUTHPLANE_SESSION_SECRET=generate-a-random-64-character-hex-value

# Local MCP resource configuration used by weather.py.
AUTHPLANE_ISSUER=http://localhost:9000
AUTHPLANE_RESOURCE=http://localhost:8000/mcp

# Added after registering a local client. Never commit real values.
AUTHPLANE_CLIENT_ID=
AUTHPLANE_CLIENT_SECRET=
